<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NIA Legal Solutions</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Inter',sans-serif;
      color:#1a1a1a;
      background:#fff;
      line-height:1.6;
    }

    a{
      text-decoration:none;
      color:inherit;
    }

    .container{
      width:90%;
      max-width:1200px;
      margin:auto;
    }

    /* =========================
       NAVBAR
    ========================== */

    header{
      background:#ffffff;
      border-bottom:1px solid #eee;
      position:sticky;
      top:0;
      z-index:1000;
    }

    .navbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:22px 0;
    }

    .logo{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .logo img{
      width:60px;
    }

    .logo-text h2{
      font-size:32px;
      color:#0b2341;
      letter-spacing:2px;
      font-weight:700;
    }

    .logo-text span{
      font-size:12px;
      letter-spacing:4px;
      color:#555;
    }

    .nav-links{
      display:flex;
      gap:35px;
      align-items:center;
    }

    .nav-links a{
      font-size:15px;
      color:#1b2a41;
      transition:0.3s;
    }

    .nav-links a:hover{
      color:#c79a4b;
    }

    .btn{
      background:#c79a4b;
      color:#fff;
      padding:14px 28px;
      border-radius:6px;
      font-weight:600;
      transition:0.3s;
      display:inline-block;
    }

    .btn:hover{
      background:#aa7f34;
    }

    /* =========================
       HERO SECTION
    ========================== */

    .hero{
      min-height:90vh;
      background:
      linear-gradient(rgba(255,255,255,0.75), rgba(255,255,255,0.75)),
      url('https://images.unsplash.com/photo-1521791136064-7986c2920216?q=80&w=1600&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
      display:flex;
      align-items:center;
    }

    .hero-content{
      max-width:650px;
      padding:80px 0;
    }

    .hero h1{
      font-family:'Playfair Display',serif;
      font-size:68px;
      line-height:1.1;
      color:#0b2341;
      margin-bottom:30px;
    }

    .hero-line{
      width:70px;
      height:3px;
      background:#c79a4b;
      margin-bottom:30px;
    }

    .hero p{
      font-size:20px;
      color:#444;
      margin-bottom:40px;
    }

    /* =========================
       PRACTICE AREA
    ========================== */

    .section{
      padding:100px 0;
    }

    .section-title{
      text-align:center;
      margin-bottom:70px;
    }

    .section-title span{
      color:#7a7a7a;
      font-size:14px;
      letter-spacing:2px;
      text-transform:uppercase;
      font-weight:600;
    }

    .section-title h2{
      font-family:'Playfair Display',serif;
      font-size:52px;
      color:#0b2341;
      line-height:1.2;
      margin-top:15px;
    }

    .title-line{
      width:60px;
      height:3px;
      background:#c79a4b;
      margin:25px auto 0;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:30px;
    }

    .card{
      background:#fff;
      border:1px solid #eee;
      padding:40px 30px;
      border-radius:10px;
      transition:0.3s;
      text-align:center;
    }

    .card:hover{
      transform:translateY(-8px);
      box-shadow:0 10px 30px rgba(0,0,0,0.08);
    }

    .card-icon{
      font-size:52px;
      margin-bottom:20px;
    }

    .card h3{
      color:#0b2341;
      margin-bottom:15px;
      font-size:24px;
    }

    .card p{
      color:#666;
      font-size:15px;
    }

    /* =========================
       ABOUT SECTION
    ========================== */

    .about{
      background:#081d3a;
      color:#fff;
    }

    .about-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:50px;
    }

    .about-text span{
      color:#c79a4b;
      letter-spacing:2px;
      font-size:14px;
      text-transform:uppercase;
    }

    .about-text h2{
      font-family:'Playfair Display',serif;
      font-size:58px;
      line-height:1.1;
      margin:25px 0;
    }

    .about-text p{
      color:#d6d6d6;
      margin-bottom:40px;
      font-size:18px;
    }

    .outline-btn{
      border:1px solid #c79a4b;
      color:#fff;
      padding:14px 28px;
      border-radius:6px;
      display:inline-block;
      transition:0.3s;
    }

    .outline-btn:hover{
      background:#c79a4b;
    }

    .about-image img{
      width:100%;
      border-radius:12px;
      object-fit:cover;
    }

    /* =========================
       CTA SECTION
    ========================== */

    .cta{
      background:#f8f8f8;
      padding:80px 0;
    }

    .cta-box{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:40px;
    }

    .cta h2{
      font-family:'Playfair Display',serif;
      font-size:48px;
      color:#0b2341;
      max-width:700px;
    }

    /* =========================
       FOOTER
    ========================== */

    footer{
      background:#081d3a;
      color:#fff;
      padding:80px 0 30px;
    }

    .footer-grid{
      display:grid;
      grid-template-columns:2fr 1fr 1fr 1.5fr;
      gap:40px;
      margin-bottom:50px;
    }

    .footer-logo h2{
      font-size:38px;
      margin-bottom:10px;
    }

    .footer-logo p{
      color:#ccc;
      max-width:280px;
    }

    .footer-column h4{
      margin-bottom:20px;
      font-size:18px;
    }

    .footer-column ul{
      list-style:none;
    }

    .footer-column ul li{
      margin-bottom:12px;
      color:#d6d6d6;
    }

    .footer-bottom{
      border-top:1px solid rgba(255,255,255,0.1);
      padding-top:25px;
      display:flex;
      justify-content:space-between;
      flex-wrap:wrap;
      color:#ccc;
      font-size:14px;
    }

    /* =========================
       RESPONSIVE
    ========================== */

    @media(max-width:991px){

      .hero h1{
        font-size:50px;
      }

      .about-grid{
        grid-template-columns:1fr;
      }

      .cta-box{
        flex-direction:column;
        align-items:flex-start;
      }

      .footer-grid{
        grid-template-columns:1fr 1fr;
      }

      .nav-links{
        display:none;
      }

    }

    @media(max-width:768px){

      .hero h1{
        font-size:42px;
      }

      .section-title h2{
        font-size:40px;
      }

      .about-text h2{
        font-size:42px;
      }

      .cta h2{
        font-size:36px;
      }

      .footer-grid{
        grid-template-columns:1fr;
      }

    }

  </style>
</head>
